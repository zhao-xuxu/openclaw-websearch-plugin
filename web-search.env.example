# Web Search Plugin 配置
# ============================================
# 填入你的 key，其他留空即可

# Tavily API Keys（逗号分隔，支持多 key 轮转）
# 免费 1000 次/月，获取: https://tavily.com
TAVILY_API_KEY=your-tavily-key-1,your-tavily-key-2

# Grok 搜索（中转站 或 本地 grok2api Docker）
# 推荐中转站: https://ai.huan666.de （每天签到可领余额，速度快）
GROK_API_URL=https://ai.huan666.de
GROK_API_KEY=your-grok-api-key
GROK_MODEL=grok-4.1-fast

# FireCrawl（可选，网页抓取的备用方案）
# 获取: https://firecrawl.dev
# FIRECRAWL_API_KEY=your-firecrawl-key
